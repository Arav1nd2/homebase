{
  "name": "hombase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:start && npm run db:migrate:local && npm run build:workers && npm run preview:workers",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres drizzle-kit migrate",
    "db:generate-migration": "DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres drizzle-kit generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:integration": "npm run db:reset && npm run db:migrate:local && npm run test:e2e && npm run db:stop",
    "build:workers": "opennextjs-cloudflare build",
    "preview:workers": "opennextjs-cloudflare preview",
    "deploy:workers": "opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "drizzle-orm": "^0.36.0",
    "next": "^15.1.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@opennextjs/cloudflare": "^1.20.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prettier": "^3.4.0",
    "supabase": "^2.109.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.86.0"
  }
}
