# Copy to `.env` (gitignored) at the repo root. Read by the Supabase CLI's
# `env()` substitution in supabase/config.toml — NOT by Wrangler (that's
# .dev.vars). Must be at the repo root, not inside supabase/.

# Must exactly match SEND_EMAIL_HOOK_SECRET in
# workers/send-email-hook/.dev.vars (minus the "v1,whsec_" prefix, which
# Supabase adds itself when signing) — Supabase signs the Send Email Hook
# webhook with this secret, and the send-email-hook Worker verifies with
# it, so both sides must agree. Generate with:
#   echo "v1,whsec_$(openssl rand -base64 32)"
SEND_EMAIL_HOOK_SECRET=
